[submodule ".registry"]
	path = .registry
	url = https://github.com/noaa-fisheries-integrated-toolbox/noaa-fisheries-integrated-toolbox.r-universe.dev
	branch = HEAD
[submodule "adnuts"]
	path = adnuts
	url = https://github.com/Cole-Monnahan-NOAA/adnuts
